{
  "name": "gymstat_web",
  "version": "1.0.0",
  "description": "Backend for Gymstat project",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "collectCoverageFrom": [
      "src/controllers/*.js",
      "src/middleware/*.js",
      "src/routes/*.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.8.9",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "node-mocks-http": "^1.14.1",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.4"
  }
}